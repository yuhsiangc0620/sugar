# Notion integration secret. Create it at https://www.notion.so/profile/integrations
NOTION_TOKEN=

# Parent page shared with the Notion integration.
# Only needed when running `npm run setup:notion` to create the databases.
NOTION_PARENT_PAGE_ID=

# Data source IDs printed by `npm run setup:notion`.
# Add these to Vercel Project Settings -> Environment Variables.
NOTION_SOUND_LOGS_DATA_SOURCE_ID=
NOTION_CANDY_EVENTS_DATA_SOURCE_ID=
NOTION_DAILY_SUMMARY_DATA_SOURCE_ID=

# Optional. Without this, SUGAR uses a deterministic local fallback summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Optional public label written into Notion as user_name.
NEXT_PUBLIC_SUGAR_USER_NAME=sugar-user
